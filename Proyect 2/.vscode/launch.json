{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "GDB: GUI Debug (Qt Test)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/taskscript_qt_test.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/Qt/6.5.3/mingw_64/bin;C:/Qt/Tools/mingw1120_64/bin;${env:PATH}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/Qt/Tools/mingw1120_64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cmake: build (debug)",
            "sourceLanguages": [
                "cpp"
            ]
        },
        {
            "name": "GDB: CLI Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/taskscript_cli.exe",
            "args": [
                "test/test06_formato_usuario.task"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "C:/Qt/6.5.3/mingw_64/bin;C:/Qt/Tools/mingw1120_64/bin;${env:PATH}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "C:/Qt/Tools/mingw1120_64/bin/gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "sourceLanguages": [
                "cpp"
            ]
        }
    ]
}
